# Copy to .env for local dev runs. In Umbrel these are set by the platform
# (APP_SEED, APP_DATA_DIR are injected by umbreld).

SECRET_KEY=change-me-locally
POSTGRES_PASSWORD=dev-postgres-password

# ── Plaid ─────────────────────────────────────────────────────────────
# Seed the defaults; the /admin/plaid_settings page persists edits to
# {DATA_DIR}/plaid_settings.json, which WINS. Leave blank and configure via
# the UI, or set them for a headless deploy.
#
# Get your Client ID + per-environment Secrets from dashboard.plaid.com →
# Developers → Keys. PLAID_ENV is sandbox | production. The redirect URI must
# EXACTLY match one registered under Developers → API → Allowed redirect URIs
# (required for OAuth banks like Wells Fargo).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=http://umbrel.local:5202/plaid/oauth_return
# Optional — leave blank for the polling pilot.
PLAID_WEBHOOK_URL=

# ── ERPNext bridge ────────────────────────────────────────────────────
# API key/secret are a per-user (System Manager) pair: ERPNext → User → API
# Access → Generate Keys. Reuse an existing key or mint a dedicated one. Bank
# Transactions take their company from the mapped Bank Account, so
# ERPNEXT_DEFAULT_COMPANY is only a fallback.
ERPNEXT_URL=http://umbrel.local:5300
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_DEFAULT_COMPANY=
# One-click import auto-creates a matching GL Account in ERPNext's Chart of
# Accounts (account_type "Bank") so a company Bank Account links a real account
# and keeps is_company_account = 1. These tune that (both optional):
#   ERPNEXT_BANK_ACCOUNT_GROUP_NAME — the parent group the per-account GL
#     Accounts go under. Stock ERPNext ships "Bank Accounts" (under Current
#     Assets → Assets); set to match yours if your CoA template names it
#     differently ("Bank", "Cash and Bank").
#   ERPNEXT_BANK_ACCOUNT_CURRENCY — fallback currency for a created GL Account
#     when the Plaid account reports no iso_currency_code.
ERPNEXT_BANK_ACCOUNT_GROUP_NAME=Bank Accounts
ERPNEXT_BANK_ACCOUNT_CURRENCY=USD

# ── v0.3.0 · auto-Supplier + categorization rules ─────────────────────
# When ON (default), a pushed transaction with a never-seen merchant_name mints
# the matching ERPNext Supplier so the Bank Transaction is linkable. Non-
# destructive (a Supplier is a reference record). supplier_group must be an
# existing Supplier Group docname (stock ERPNext: "All Supplier Groups").
ERPNEXT_AUTO_CREATE_SUPPLIERS=true
ERPNEXT_DEFAULT_SUPPLIER_GROUP=All Supplier Groups
ERPNEXT_DEFAULT_SUPPLIER_COUNTRY=United States
# The rules engine (/admin/rules) generates Journal Entries from matched
# transactions. OFF by default: rules can be authored + tested without firing,
# because a wrong auto-JE is worse than none. Flip to true only once your rules
# are trusted. AUTO_SUBMIT=false leaves each JE as a Draft for review.
ERPNEXT_AUTO_GENERATE_JOURNAL_ENTRIES=false
ERPNEXT_JOURNAL_ENTRY_AUTO_SUBMIT=false
ERPNEXT_JOURNAL_ENTRY_REVIEW_STATE=pending_review

# ── Encryption + scheduling ───────────────────────────────────────────
# Blank FERNET_KEY autogenerates one on first boot and persists it to
# {DATA_DIR}/fernet.key. Back that file up — losing it means re-linking every
# bank. SYNC_INTERVAL_HOURS is the background poll cadence.
FERNET_KEY=
SYNC_INTERVAL_HOURS=6
SCHEDULER_ENABLED=true

# ── v0.3.5 · self-healing DB auth ─────────────────────────────────────
# Postgres bakes the bankbridge role's password in at FIRST volume init. If a
# later deploy hands the app a different password (e.g. an earlier init ran
# while APP_SEED was blank), every connection fails with "password
# authentication failed for user 'bankbridge'". On boot the app detects that
# specific error and rotates the role's password (via a superuser connection)
# to match the current value — no volume wipe, no manual step.
#   AUTO_RECOVER_DB_AUTH — set false to disable the self-heal.
#   DB_SUPERUSER / DB_SUPERUSER_PASSWORD — the superuser used for the rotation.
#     Password falls back to POSTGRES_PASSWORD, then SECRET_KEY. NOTE: the stock
#     compose runs the db with POSTGRES_USER=bankbridge, so `bankbridge` IS the
#     only superuser — for a reachable superuser during drift, run the db with a
#     distinct superuser, set POSTGRES_HOST_AUTH_METHOD=trust on the isolated db
#     network, or just pin POSTGRES_PASSWORD so it never drifts in the first place.
AUTO_RECOVER_DB_AUTH=true
DB_SUPERUSER=postgres
DB_SUPERUSER_PASSWORD=
